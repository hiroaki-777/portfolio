{% macro render(w, num) %}
{%- set d = w.data -%}
{%- set delay = ' data-delay="' + d.delay + '"' if d.delay else '' -%}
{%- if d.kind == "faces" -%}
        <article class="work-item reveal"{{ delay | safe }}>
          <div class="faces{% if d.faces_stack %} faces-stack{% endif %}">
            {%- for img in d.images %}
            <figure class="face">
              <div class="media hov" data-ratio="{{ d.ratio or '3-4' }}">{% if loop.first %}<span class="redchip"></span>{% endif %}<img src="{{ img.src }}" alt="{{ img.alt or d.title }}"></div>
              <figcaption>{{ img.caption }}</figcaption>
            </figure>
            {%- endfor %}
          </div>
          <p class="wnum">Work {{ num }}</p>
          <h2 class="wtitle">{{ d.title }}<span class="dot">.</span></h2>
          <p class="wdesc">{{ d.description }}</p>
          <div class="roles">{% for r in d.roles %}<span>{{ r }}</span>{% endfor %}</div>
          {% if d.term %}<p class="term">{{ d.term }}</p>{% endif %}
        </article>
{%- elif d.kind == "single" -%}
        <article class="work-item reveal"{{ delay | safe }}>
          <div class="media" data-ratio="{{ d.ratio or '1-1' }}"><span class="redchip"></span><img src="{{ d.images[0].src }}" alt="{{ d.images[0].alt or d.title }}"></div>
          <p class="wnum">Work {{ num }}</p>
          <h2 class="wtitle">{{ d.title }}<span class="dot">.</span></h2>
          <p class="wdesc">{{ d.description }}</p>
          <div class="roles">{% for r in d.roles %}<span>{{ r }}</span>{% endfor %}</div>
          {% if d.term %}<p class="term">{{ d.term }}</p>{% endif %}
        </article>
{%- elif d.kind == "banner" -%}
        <article class="work-item reveal"{{ delay | safe }}>
          <div class="banner-stack">
            {%- for img in d.images %}
            <div class="media hov">{% if loop.first %}<span class="redchip"></span>{% endif %}<img src="{{ img.src }}" alt="{{ img.alt or d.title }}"></div>
            {%- endfor %}
          </div>
          <p class="wnum">Work {{ num }}</p>
          <h2 class="wtitle">{{ d.title }}<span class="dot">.</span></h2>
          <p class="wdesc">{{ d.description }}</p>
          <div class="roles">{% for r in d.roles %}<span>{{ r }}</span>{% endfor %}</div>
          {% if d.term %}<p class="term">{{ d.term }}</p>{% endif %}
        </article>
{%- elif d.kind == "logo" -%}
        <article class="work-item reveal"{{ delay | safe }}>
          <div class="logo-grid" style="margin-bottom: 26px;">
            <div class="logo-stage light" style="aspect-ratio:4/3;">
              <span class="redchip"></span>
              <img class="logo-img" src="{{ d.images[0].src }}" alt="{{ d.title }}">
            </div>
            <div class="logo-detail">
              <div class="logo-chip light-chip"><img class="logo-img" src="{{ d.images[0].src }}" alt="on light"><span class="cap">on light</span></div>
              <div class="logo-chip dark-chip"><img class="logo-img inv" src="{{ d.images[0].src }}" alt="on dark"><span class="cap">on dark</span></div>
            </div>
          </div>
          <p class="wnum">Work {{ num }}</p>
          <h2 class="wtitle">{{ d.title }}<span class="dot">.</span></h2>
          <p class="wdesc">{{ d.description }}</p>
          <div class="roles">{% for r in d.roles %}<span>{{ r }}</span>{% endfor %}</div>
          {% if d.term %}<p class="term">{{ d.term }}</p>{% endif %}
        </article>
{%- elif d.kind == "sns" -%}
      <article class="work-item reveal"{{ delay | safe }}>
        <div class="sns-grid">
          <div class="media hov">
            <span class="redchip"></span>
            <img src="{{ d.images[0].src }}" alt="{{ d.title }}">
          </div>
          <div>
            <p class="wnum">Work {{ num }}</p>
            <h2 class="wtitle">{{ d.title }}<span class="dot">.</span></h2>
            <p class="wdesc">{{ d.description }}</p>
            <div class="roles">{% for r in d.roles %}<span>{{ r }}</span>{% endfor %}</div>
            {% if d.link %}<div style="margin-top: 30px;">
              <a class="btn-ig" href="{{ d.link }}" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
                </svg>
                {{ d.link_label or "View" }}
              </a>
            </div>{% endif %}
          </div>
        </div>
      </article>
{%- endif -%}
{% endmacro %}
